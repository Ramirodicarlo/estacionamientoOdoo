<?xml version="1.0" encoding="utf-8"?>
<odoo>
  <!-- Vistas Cliente -->
  <record id="estacionamiento_cliente_vista" model="ir.ui.view">
      <field name="name">Lista de Clientes</field>
      <field name="model">estacionamiento.cliente</field>
      <field name="arch" type="xml">
          <list string="Clientes">
              <field name="cuit"/>
              <field name="nombre"/>
              <field name="vehiculos"/>
          </list>
      </field>
  </record>

  <record id="estacionamiento_cliente_form" model="ir.ui.view">
      <field name="name">Formulario de Cliente</field>
      <field name="model">estacionamiento.cliente</field>
      <field name="arch" type="xml">
          <form string="Cliente">
              <sheet>
                  <group>
                      <field name="cuit"/>
                      <field name="nombre"/>
                  </group>
                  <notebook>
                      <page string="Vehículos Asignados">
                          <field name="vehiculos">
                              <list>
                                  <field name="patente"/>
                                  <field name="mensualidad"/>
                              </list>
                          </field>
                      </page>
                  </notebook>
              </sheet>
          </form>
      </field>
  </record>

  <!-- Acción Cliente -->
  <record id="estacionamiento_cliente_accion" model="ir.actions.act_window">
      <field name="name">Clientes</field>
      <field name="res_model">estacionamiento.cliente</field>
      <field name="type">ir.actions.act_window</field>
      <field name="view_mode">list,form</field>
  </record>

  <!-- Menú Cliente -->
  <menuitem id="estacionamiento_cliente_menu"
    name="Clientes"
    parent="estacionamiento_menu"
    action="estacionamiento_cliente_accion"
    sequence="4"
  />
</odoo>
