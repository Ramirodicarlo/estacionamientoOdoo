<?xml version="1.0" encoding="utf-8"?>
<odoo>
  <!-- Vistas Lugar -->
  <record id="estacionamiento_lugar_vista" model="ir.ui.view">
      <field name="name">Lista de Lugares</field>
      <field name="model">estacionamiento.lugar</field>
      <field name="arch" type="xml">
          <list string="Lugares">
              <field name="lugar_id"/>
              <field name="vehiculo_id"/>
              <field name="ocupado"/>
          </list>
      </field>
  </record>

  <!-- Acción Lugar -->
  <record id="estacionamiento_lugar_accion" model="ir.actions.act_window">
      <field name="name">Lugar</field>
      <field name="res_model">estacionamiento.lugar</field>
      <field name="type">ir.actions.act_window</field>
      <field name="view_mode">list,form</field>
  </record>

  <!-- Menú Lugar -->
  <menuitem id="estacionamiento_lugar_menu"
    name="Lugares"
    parent="estacionamiento_menu"
    action="estacionamiento_lugar_accion"
    sequence="2"
  />
</odoo>
