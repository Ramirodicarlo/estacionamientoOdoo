<?xml version="1.0" encoding="utf-8"?>
<odoo>
  <!-- Vistas Vehículo -->
  <record id="estacionamiento_vehiculo_vista" model="ir.ui.view">
      <field name="name">Lista de Vehiculos</field>
      <field name="model">estacionamiento.vehiculo</field>
      <field name="arch" type="xml">
          <list string="Vehiculos">
              <field name="patente"/>
              <field name="cliente_id"/>
              <field name="estacionado"/>
              <field name="mensualidad_activa"/>
          </list>
      </field>
  </record>

  <record id="estacionamiento_vehiculo_form" model="ir.ui.view">
      <field name="name">estacionamiento.vehiculo.form</field>
      <field name="model">estacionamiento.vehiculo</field>
      <field name="arch" type="xml">
          <form string="Vehículo">
              <sheet>
                  <group>
                      <field name="patente"/>
                      <field name="cliente_id"/>
                      <field name="estacionado"/>
                      <field name="mensualidad_activa"/>
                  </group>
                  <notebook>
                      <page string="Mensualidades">
                          <field name="mensualidad">
                              <list string="Mensualidades">
                                  <field name="fecha_inicio"/>
                                  <field name="fecha_vencimiento"/>
                                  <field name="estado"/>
                              </list>
                          </field>
                      </page>
                  </notebook>
              </sheet>
          </form>
      </field>
  </record>

  <!-- Acción Vehículo -->
  <record id="estacionamiento_vehiculo_accion" model="ir.actions.act_window">
      <field name="name">Vehiculos</field>
      <field name="res_model">estacionamiento.vehiculo</field>
      <field name="type">ir.actions.act_window</field>
      <field name="view_mode">list,form</field>
  </record>

  <!-- Menú Vehículo -->
<menuitem id="estacionamiento_menu" name="Estacionamiento" />

  <menuitem id="estacionamiento_vehiculo_menu"
    name="Vehiculos"
    parent="estacionamiento_menu"
    action="estacionamiento_vehiculo_accion"
    sequence="1"
  />
</odoo>
